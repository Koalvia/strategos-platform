# Plantilla del ./.env que vive EN EL SERVIDOR, junto a docker-compose.prod.yml.
# Solo se usa para la INTERPOLACIÓN de la compose de prod (no es el .env de la app).
# Cópialo a ~/strategos-platform/.env en el VPS y rellena los valores.
# NO lo commitees con valores reales.

# Red docker EXTERNA donde vive el Caddy de entrada del VPS (repo Koalvia/infra,
# el que tiene 80/443). strategos-caddy (su Caddy interno) se cuelga de esta red
# para que el Caddy de entrada lo alcance por strategos-caddy:80.
PROXY_NETWORK=proxy

# Credenciales de Postgres del contenedor db (usa una password fuerte).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esto-por-algo-fuerte
POSTGRES_DB=strategos_db

# (Opcional) Fijar imágenes a un tag concreto para rollback. Por defecto el CI
# usa :latest. Para volver a una versión anterior, pon aquí el tag sha-XXXXXXX
# y relanza `docker compose -f docker-compose.prod.yml up -d`.
# BACKEND_IMAGE=ghcr.io/davidalonsobadia/strategos-platform-backend:sha-abc1234
# FRONTEND_IMAGE=ghcr.io/davidalonsobadia/strategos-platform-frontend:sha-abc1234
